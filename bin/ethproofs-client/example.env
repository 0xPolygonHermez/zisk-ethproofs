# Set the following environment variables and rename/copy the file to .env

# URL for the block input file generation server
INPUT_GEN_SERVER_URL=ws://localhost:8765

# Ethproofs API configuration
ETHPROOFS_API_URL=https://staging--ethproofs.netlify.app/api/v0
ETHPROOFS_API_TOKEN=<ETHPROOFS_API_TOKEN>
ETHPROOFS_CLUSTER_ID=1

# ELF file used to prove Ethereum blocks
ELF_FILE=zec-keccakf-k256-sha2-bn254.elf

# Prove CLI parameters when not using distributed mode
PROVE_PARAMS=

# Compute capacity of the proof when using distributed mode
COMPUTE_CAPACITY=10

# Folder where the block inputs files are stored
INPUTS_FOLDER=upload_inputs

# Telegram bot configuration for notifications
TELEGRAM_BOT_TOKEN=<TELEGRAM_BOT_TOKEN>
TELEGRAM_CHAT_ID=<TELEGRAM_CHAT_ID>
TELEGRAM_PREFIX_MSG="Test"